# Server
PORT=3000
NODE_ENV=development

# Azure Cosmos DB (Serverless)
COSMOS_ENDPOINT=https://bullfight-db.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key-here
COSMOS_DATABASE=bullfight

# Azure Blob Storage (profile pics)
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER=profile-pics

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple Sign-In
APPLE_CLIENT_ID=com.bullfight.app
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./keys/apple-auth-key.p8

# Admin seed script (scripts/seed-admin.ts)
SEED_ADMIN_EMAIL=admin@bf.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
